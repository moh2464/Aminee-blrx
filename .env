# Free Fire Bot Configuration

# Team code to join (REQUIRED - Change this to your team code)
TEAM_CODE=123456

# Run browser in headless mode (True/False)
HEADLESS_MODE=False

# Time to wait in match (seconds)
MATCH_WAIT_TIME=25

# Sleep time between loop iterations (seconds)
LOOP_SLEEP_TIME=3

# WebDriver timeout (seconds) - Increase if you have slow internet
DRIVER_TIMEOUT=10

# Chrome/Chromium path (optional - leave empty to auto-detect)
CHROME_PATH=

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file name
LOG_FILE=bot.log

# Free Fire Web App URL
FF_URL=https://freefiremax.web.app

# Login credentials (optional - leave empty to skip login)
FF_LOGIN_EMAIL=
FF_LOGIN_PASSWORD=

# Maximum number of join team retries
MAX_RETRIES=3

# Delay between retries (seconds)
RETRY_DELAY=5