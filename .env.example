# Free Fire Bot Configuration

# Team code to join
TEAM_CODE=123456

# Run browser in headless mode (True/False)
HEADLESS_MODE=False

# Time to wait in match (seconds)
MATCH_WAIT_TIME=25

# Sleep time between loop iterations (seconds)
LOOP_SLEEP_TIME=3

# WebDriver timeout (seconds)
DRIVER_TIMEOUT=10

# Chrome/Chromium path (optional)
CHROME_PATH=

# Logging
LOG_LEVEL=INFO
LOG_FILE=bot.log

# Free Fire Web App
FF_URL=https://freefiremax.web.app
FF_LOGIN_EMAIL=your_email@example.com
FF_LOGIN_PASSWORD=your_password