# Free Fire Bot Configuration Template
# Copy this file to .env and update with your settings

# ═══════════════════════════════════════════════════════════════
# REQUIRED SETTINGS
# ═══════════════════════════════════════════════════════════════

# Your Free Fire team code (REQUIRED - Change this!)
TEAM_CODE=123456

# ═══════════════════════════════════════════════════════════════
# BOT BEHAVIOR SETTINGS
# ═══════════════════════════════════════════════════════════════

# Run browser in headless mode (hide window)
# Options: True, False
HEADLESS_MODE=False

# Time to wait in match before exiting (seconds)
MATCH_WAIT_TIME=25

# Sleep time between loop iterations (seconds)
# Lower values = more responsive, higher = less CPU usage
LOOP_SLEEP_TIME=3

# ═══════════════════════════════════════════════════════════════
# RETRY & PERFORMANCE SETTINGS
# ═══════════════════════════════════════════════════════════════

# Maximum number of join team retries on failure
MAX_RETRIES=3

# Delay between retry attempts (seconds)
RETRY_DELAY=5

# WebDriver timeout (seconds) - increase if you have slow internet
# Recommended: 10-20 seconds
DRIVER_TIMEOUT=10

# ═══════════════════════════════════════════════════════════════
# BROWSER & CHROME SETTINGS
# ═══════════════════════════════════════════════════════════════

# Chrome/Chromium installation path (optional - leave empty to auto-detect)
# Windows example: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux example: /usr/bin/google-chrome
CHROME_PATH=

# ═══════════════════════════════════════════════════════════════
# LOGGING SETTINGS
# ═══════════════════════════════════════════════════════════════

# Logging level
# Options: DEBUG (detailed), INFO (default), WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file name (saved in logs/ directory)
LOG_FILE=bot.log

# ═══════════════════════════════════════════════════════════════
# FREE FIRE WEB APP SETTINGS
# ═══════════════════════════════════════════════════════════════

# Free Fire web app URL
FF_URL=https://freefiremax.web.app

# ═══════════════════════════════════════════════════════════════
# LOGIN SETTINGS (Optional)
# ═══════════════════════════════════════════════════════════════

# Free Fire game email address (optional - leave empty to skip login)
FF_LOGIN_EMAIL=

# Free Fire game password (optional - leave empty to skip login)
# ⚠️  WARNING: Never commit real password to version control
FF_LOGIN_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# QUICK START GUIDE
# ═══════════════════════════════════════════════════════════════
# 
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and set your TEAM_CODE:
#    nano .env  (or use your preferred editor)
#
# 3. Run the bot:
#    python main.py
#
# 4. Check logs:
#    tail -f logs/bot.log
#
# ═══════════════════════════════════════════════════════════════